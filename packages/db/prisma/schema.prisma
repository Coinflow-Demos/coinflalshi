generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String
  name                   String
  isGuest                Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  wallet                 Wallet?
  positions              Position[]
  transactions           Transaction[]
  savedPaymentMethods    SavedPaymentMethod[]
  cryptoDepositAddresses CryptoDepositAddress[]
}

model Wallet {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceCents Int      @default(0)
  updatedAt    DateTime @updatedAt
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_PAYOUT
  BET_REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentMethodType {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  CRYPTO
  LEDGER
}

model Transaction {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              TransactionType
  status            TransactionStatus  @default(PENDING)
  amountCents       Int
  method            PaymentMethodType?
  coinflowPaymentId String?            @unique
  metadata          Json?
  createdAt         DateTime           @default(now())

  @@index([userId])
  @@index([coinflowPaymentId])
}

model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardToken String
  brand     String
  last4     String
  expMonth  String
  expYear   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model CryptoDepositAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chain     String
  token     String
  address   String
  createdAt DateTime @default(now())

  @@unique([userId, chain, token])
}

enum MarketStatus {
  OPEN
  RESOLVING
  RESOLVED
}

model Market {
  id                String       @id @default(cuid())
  slug              String       @unique
  category          String
  title             String
  subtitle          String?
  imageEmoji        String?
  status            MarketStatus @default(OPEN)
  volumeCents       Int          @default(0)
  closesAt          DateTime
  resolvesAt        DateTime
  resolvedOutcomeId String?
  createdAt         DateTime     @default(now())
  outcomes          Outcome[]
  positions         Position[]
  activity          MarketActivity[]

  // Null for the built-in/template-spawned markets; set for
  // user-submitted ones (Manifold-style "anyone can create a market").
  creatorId   String?
  creatorName String?

  @@index([status, resolvesAt])
}

// Simulated third-party trade activity — not tied to real users or the
// wallet ledger. Generated alongside a market's price history purely to
// make volume and a "recent trades" feed look like a live, populated
// market instead of an empty one with a single real trader.
model MarketActivity {
  id          String   @id @default(cuid())
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcomeId   String
  traderName  String
  shares      Int
  priceCents  Int
  at          DateTime @default(now())

  @@index([marketId, at])
}

model Outcome {
  id         String       @id @default(cuid())
  marketId   String
  market     Market       @relation(fields: [marketId], references: [id], onDelete: Cascade)
  label      String
  priceCents Int
  positions  Position[]
  pricePoints PricePoint[]

  @@index([marketId])
}

// Time series of an outcome's price. Seeded with a full synthetic random
// walk at market creation (see createMarket.ts) so charts have realistic
// movement from the moment a market appears, and appended to whenever a
// trade nudges the price. Readers filter to `at <= now` so a market's chart
// only ever reveals price history up to the present, even though the whole
// walk is precomputed.
model PricePoint {
  id         String   @id @default(cuid())
  outcomeId  String
  outcome    Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  priceCents Int
  at         DateTime @default(now())

  @@index([outcomeId, at])
}

enum PositionStatus {
  OPEN
  WON
  LOST
  REFUNDED
}

model Position {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId        String
  market          Market         @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcomeId       String
  outcome         Outcome        @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  shares          Int
  entryPriceCents Int
  costCents       Int
  status          PositionStatus @default(OPEN)
  payoutCents     Int?
  createdAt       DateTime       @default(now())

  @@index([userId])
  @@index([marketId])
}
